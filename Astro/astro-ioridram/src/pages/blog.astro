---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";
import { getCollection } from "astro:content";

const pageTitle = "ioridram Blog";
const allPosts = await getCollection("posts");
---

<BaseLayout pageTitle={"blog/ioridram"}>
  <p>ブログページは現在準備中です。しばらくお待ちください。</p>
  <ul>
    <!-- <li><a href="../post/post-1">記事1</a></li>
    <li><a href="post/post-2">記事2</a></li>
    <li><a href="post/post-3">記事3</a></li> -->
    {
      allPosts.map((post) => (
        <BlogPost
          url={`/posts/${post.slug}`}
          title={post.data.title}
          image={post.data.image}
        />
      ))
    }
  </ul>
</BaseLayout>
