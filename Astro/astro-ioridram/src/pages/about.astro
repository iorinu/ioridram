---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "About Iori's Portfolio";
---

<BaseLayout pageTitle={pageTitle}>
  <section>
    <h1>Iori's Portfolio<span class="cursor"></span></h1>
    <div class="subtitle">Graduate Student</div>
    <p style="margin-top: 20px">
      <a href="https://github.com/tomatotamada" target="_blank"
        >GitHub: tomatotamada</a
      >
    </p>
    <h2>About Me</h2>
    <p>
      工学部所属。主に連合学習（Federated
      Learning）やプライバシー保護技術について研究しています。<br />
      また、CTF（Capture The Flag）を通じてセキュリティ技術の学習も行っています。
    </p>
  </section>

  <section>
    <h2>Research Interests</h2>
    <ul>
      <li>
        <strong>Federated Learning Frameworks</strong>
        <span class="tag">Flower</span>
        <span class="tag">Pytorch</span>
      </li>
      <li>
        <strong>Cybersecurity</strong>
        <span class="tag">CTF</span>
        <span class="tag">Security</span>
      </li>
    </ul>
  </section>

  <!--
  <section>
    <h2>Projects</h2>
    <ul>
      <li>
        <strong>Graduation Thesis</strong><br />
        機械学習モデルの分散学習における効率化とプライバシー保護に関する研究。
      </li>
      <li>
        <strong>X Post App</strong><br />
        APIを使用したシンプルな投稿アプリケーションの開発。
      </li>
      <li>
        <strong>Algorithm & Logic</strong><br />
        C++およびPythonを用いたアルゴリズム実装と最適化。
      </li>
    </ul>
  </section>
  -->

  <section>
    <h2>Environment</h2>
    <p>
      日常的に使用している開発環境です。<br /><br />
      Editor: <span class="tag">Neovim</span><br />
      Terminal: <span class="tag">WezTerm</span><br />
      OS: <span class="tag">WSL: Ubuntu</span>
    </p>
  </section>
</BaseLayout>
