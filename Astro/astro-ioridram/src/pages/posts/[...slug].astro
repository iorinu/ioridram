---
import { getCollection, render } from "astro:content";
import MarkdownPostLayout from "../../layouts/MarkdownPostLayout.astro";
export async function getStaticPaths() {
  const blogEntries = await getCollection("posts", ({ data }) => !data.draft);
  const sorted = blogEntries.sort(
    (a, b) => new Date(a.data.pubDate).getTime() - new Date(b.data.pubDate).getTime()
  );
  return sorted.map((entry, i) => ({
    params: { slug: entry.data.slug },
    props: {
      entry,
      prevPost: sorted[i - 1] ?? null,
      nextPost: sorted[i + 1] ?? null,
    },
  }));
}

const { entry, prevPost, nextPost } = Astro.props;
const { Content } = await render(entry);
---

<MarkdownPostLayout frontmatter={entry.data} prevPost={prevPost} nextPost={nextPost}>
  <Content />
</MarkdownPostLayout>
