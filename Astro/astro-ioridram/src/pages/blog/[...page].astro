---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPost from "../../components/BlogPost.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection("posts", ({ data }) => !data.draft);
  allPosts.sort((a, b) => {
    const numA = parseInt(a.data.slug.match(/\d+/)?.[0] ?? "0");
    const numB = parseInt(b.data.slug.match(/\d+/)?.[0] ?? "0");
    return numB - numA;
  });
  return paginate(allPosts, { pageSize: 10 });
}

const { page } = Astro.props;
---

<BaseLayout pageTitle={"blog/ioridram"} description="ioriのブログ。プログラミング・CTF・日常などについての記事一覧。">
  <p>ブログページは現在準備中です。しばらくお待ちください。</p>
  <ul>
    {
      page.data.map((post) => (
        <BlogPost
          url={`/posts/${post.data.slug}`}
          title={post.data.title}
          image={post.data.image}
          pubDate={post.data.pubDate}
        />
      ))
    }
  </ul>

  <nav class="pagination">
    {page.url.prev && <a href={page.url.prev} class="pagination-btn">&lt;&lt; prev</a>}
    <div class="pagination-numbers">
      {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((num) => (
        <a
          href={num === 1 ? "/blog" : `/blog/${num}`}
          class={`pagination-num ${num === page.currentPage ? "current" : ""}`}
        >
          {num}
        </a>
      ))}
    </div>
    {page.url.next && <a href={page.url.next} class="pagination-btn">next &gt;&gt;</a>}
  </nav>
</BaseLayout>

<style>
  ul { list-style: none; padding: 0; }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 2rem;
  }

  .pagination-btn {
    padding: 8px 20px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent-color);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .pagination-btn:hover {
    border-color: rgba(106, 0, 255, 0.4);
    box-shadow: 0 0 15px rgba(106, 0, 255, 0.2);
    transform: translateY(-2px);
  }

  .pagination-numbers { display: flex; gap: 8px; }

  .pagination-num {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .pagination-num.current {
    background: linear-gradient(135deg, rgba(255, 0, 60, 0.3), rgba(106, 0, 255, 0.3));
    border-color: var(--sub-color);
    color: #fff;
    -webkit-text-fill-color: #fff;
    box-shadow: 0 0 15px rgba(106, 0, 255, 0.3);
  }

  .pagination-num:hover:not(.current) {
    border-color: rgba(255, 0, 60, 0.4);
    transform: translateY(-2px);
  }
</style>
