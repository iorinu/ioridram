---
const { url, title, image, pubDate } = Astro.props;
---

<li class="blog-post-item">
  {image && <img src={image.url} alt={image.alt || ""} class="thumbnail" />}
  <div class="post-info">
    <a href={url} class="title">{title}</a>
    {pubDate && <time class="pub-date">{new Date(pubDate).toLocaleDateString("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit" })}</time>}
  </div>
</li>

<style>
  /* グラスモーフィズムカード */
  .blog-post-item {
    display: flex;
    align-items: center;
    margin-bottom: 1.2rem;
    gap: 18px;
    padding: 16px;
    background: rgba(20, 20, 25, 0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    position: relative;
    overflow: hidden;
  }

  .blog-post-item::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 0, 60, 0.05),
      rgba(106, 0, 255, 0.05),
      transparent
    );
    transition: left 0.6s ease;
  }

  .blog-post-item:hover {
    transform: translateX(8px);
    border-color: rgba(106, 0, 255, 0.3);
    box-shadow: 0 8px 30px rgba(106, 0, 255, 0.15),
                0 0 0 1px rgba(106, 0, 255, 0.1);
  }

  .blog-post-item:hover::before {
    left: 100%;
  }

  /* サムネイル */
  .thumbnail {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 8px;
    border: 2px solid rgba(255, 255, 255, 0.1);
    transition: all 0.4s ease;
    flex-shrink: 0;
  }

  .blog-post-item:hover .thumbnail {
    border-color: rgba(255, 0, 60, 0.5);
    box-shadow: 0 0 20px rgba(255, 0, 60, 0.3);
  }

  /* 投稿情報 */
  .post-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pub-date {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
  }

  /* タイトル */
  .title {
    font-weight: bold;
    font-size: 1.2rem;
    transition: all 0.3s ease;
    border-bottom: none;
  }

  .blog-post-item:hover .title {
    background: linear-gradient(135deg, #ff003c, #6a00ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
